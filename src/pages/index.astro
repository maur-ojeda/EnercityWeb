---
import Layout from '../layouts/layout.astro';
import { Navbar } from '../components/organisms/navbar';
import { Hero } from '../components/organisms/hero';
import { StatsBar } from '../components/organisms/stats-bar';
import { FeatureIndustrial } from '../components/organisms/feature-industrial';
import { SolutionsGrid } from '../components/organisms/solutions-grid';
import { GuaranteeBanner } from '../components/organisms/guarantee-banner';
import { SavingsCalculator } from '../components/organisms/savings-calculator';
import { ContactCta } from '../components/organisms/contact-cta';
import { Footer } from '../components/organisms/footer';
import { supabase } from '../lib/supabase';

import { Check, ChevronLeft, ChevronRight, Loader2, Info, Zap, BarChart3, Shield } from 'lucide-react';


const { data: comunasData, error: comunasError } = await supabase
  .from('comunas')
  .select('id, nombre, activa, region, radiacion_ghi, tarifa_est' )
  .eq('activa', true)
  .order('nombre', { ascending: true });

const comunas = (comunasData || []).map((c: any) => ({
  id: c.id,
  nombre: c.nombre,
  activa: c.activa,
  region: c.region || '',
  radiacion_ghi: c.radiacion_ghi || '',
  tarifa_est: c.tarifa_est || '',
}));

const hasErrors = !!comunasError;
---

<Layout title="Enercity - Energia Solar para Chile">
  <Navbar  client:load />
  
  <main>
    <Hero client:load/>
    <StatsBar client:visible/>
    <FeatureIndustrial client:visible/>
    <SolutionsGrid client:visible/>
    <GuaranteeBanner client:visible/>
    {hasErrors ? (
      <section className="py-20 bg-gray-50" id="simulador">
        <div className="container mx-auto px-4 text-center">
          <div className="bg-red-50 border border-red-200 rounded-lg p-4 text-red-700 max-w-md mx-auto">
            Error al cargar los datos. Por favor intenta mas tarde.
          </div>
        </div>
      </section>
    ) : (
      <SavingsCalculator client:load comunas={comunas} />
      
    )}
    
    <ContactCta client:visible />
  </main>
  
  <Footer />
</Layout>
