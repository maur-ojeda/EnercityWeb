---
import SolarWizard from '../components/SolarWizard';
import { supabase } from '../lib/supabase';
import type { Comuna, Kit } from '../types/simulation';

const { data: kits, error: kitsError } = await supabase
  .from('precios_kits')
  .select('*')
  .order('consumo_bruto', { ascending: true });

const { data: comunas, error: comunasError } = await supabase
  .from('comunas')
  .select('*')
  .eq('activa', true)
  .order('nombre', { ascending: true });

const typedKits: Kit[] = (kits || []).map(kit => ({
  id: kit.id,
  consumoBruto: kit.consumo_bruto,
  amperajeNecesario: kit.amperaje_necesario,
  inversorKw: Number(kit.inversor_kw),
  paneles: kit.paneles,
  kwp: Number(kit.kwp),
  precioNetoBase: kit.precio_neto_base,
}));

const typedComunas: Comuna[] = (comunas || []).map(c => ({
  id: c.id,
  nombre: c.nombre,
  activa: c.activa,
  region: c.region || '',
}));

const hasErrors = kitsError || comunasError;
---

<html lang="es">
  <head>
    <meta charset="utf-8" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <meta name="viewport" content="width=device-width" />
    <meta name="generator" content={Astro.generator} />
    <title>Simulador Solar Enercity</title>
  </head>
  <body class="bg-gray-100 min-h-screen">
    <div class="container mx-auto px-4 py-8">
      <div class="text-center mb-8">
        <h1 class="text-4xl font-bold text-emerald-700 mb-2">☀️ Enercity</h1>
        <p class="text-gray-600">Simulador de Energía Solar</p>
      </div>
      
      {hasErrors ? (
        <div class="bg-red-50 border border-red-200 rounded-lg p-4 text-red-700 text-center">
          Error al cargar los datos. Por favor intenta más tarde.
        </div>
      ) : (
        <SolarWizard client:load comunas={typedComunas} />
      )}
      
      <footer class="text-center mt-8 text-gray-500 text-sm">
        <p>© 2026 Enercity. Todos los derechos reservados.</p>
      </footer>
    </div>
  </body>
</html>
