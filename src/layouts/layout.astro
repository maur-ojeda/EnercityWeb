---
import '../styles/global.css';

interface Props {
  title: string;
  description?: string;
}

const { title, description = "Simula tu ahorro con paneles solares. Cotización personalizada en minutos para tu hogar o empresa en Chile." } = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, Astro.site).href;
const siteName = "Enercity";
const siteUrl = "https://paneles-solares.cl";
const ogTitle = "Enercity — Simulador de Paneles Solares en Chile";
const ogDescription = "Simula tu ahorro con paneles solares. Cotización personalizada en minutos para tu hogar o empresa en Chile.";
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/svg+xml" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Rubik:wght@400;500;700;900&display=swap" />
    <meta name="generator" content={Astro.generator} />

    <!-- Canonical URL -->
    <link rel="canonical" href={canonicalURL} />

    <!-- Primary Meta Tags -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="author" content={siteName} />

    <!-- Open Graph / Facebook -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={ogTitle} />
    <meta property="og:description" content={ogDescription} />
    <meta property="og:site_name" content={siteName} />
    <meta property="og:locale" content="es_CL" />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={ogTitle} />
    <meta name="twitter:description" content={ogDescription} />

    <!-- JSON-LD Structured Data -->
    <script type="application/ld+json" set:html={JSON.stringify({
      "@context": "https://schema.org",
      "@type": "Organization",
      "name": siteName,
      "url": siteUrl,
      "logo": "https://paneles-solares.cl/logo.png",
      "areaServed": {
        "@type": "Country",
        "name": "Chile"
      },
      "serviceType": "Instalación de paneles solares",
      "description": "Simula tu ahorro con paneles solares en Chile. Cotización personalizada para hogares y empresas."
    })} />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <slot />
  </body>
</html>
